# Django
DEBUG=True
DJANGO_ENV=development
SECRET_KEY=replace-with-a-secure-secret-key-at-least-32-characters-long
ALLOWED_HOSTS=127.0.0.1,localhost
TIME_ZONE=Asia/Kolkata

# Database (Option A: discrete PostgreSQL vars)
POSTGRES_DB=factory_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Database (Option B: DATABASE_URL, overrides the vars above)
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/factory_db
DB_CONN_MAX_AGE=60

# JWT
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=7

# API
PAGE_SIZE=20
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOWED_ORIGIN_REGEXES=
CORS_ALLOW_ALL_ORIGINS=False
CSRF_TRUSTED_ORIGINS=http://localhost:3000

# Security (recommended True in production)
USE_X_FORWARDED_HOST=True
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
